# ============================================================
# SaaS POS — Root Environment Variables Example
# Copy to .env.local (never commit .env.local to git)
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY...
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY...  # NEVER expose client-side

# ─── PowerSync ───────────────────────────────────────────────
# Your self-hosted PowerSync instance URL (or cloud URL)
POWERSYNC_URL=https://YOUR_POWERSYNC_INSTANCE.powersync.journeyapps.com

# ─── Environment ─────────────────────────────────────────────
NODE_ENV=development
