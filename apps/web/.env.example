# ============================================================
# Web Dashboard (Vite) — Environment Variables
# Vite requires VITE_ prefix for client-side vars.
# Copy to apps/web/.env.local
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY...

# ─── PowerSync (web dashboard analytics) ─────────────────────
VITE_POWERSYNC_URL=https://YOUR_POWERSYNC_INSTANCE.powersync.journeyapps.com
