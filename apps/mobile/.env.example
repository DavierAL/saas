# ============================================================
# Mobile App (Expo) — Environment Variables
# Expo requires EXPO_PUBLIC_ prefix for client-side vars.
# Copy to apps/mobile/.env.local
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY...

# ─── PowerSync ───────────────────────────────────────────────
EXPO_PUBLIC_POWERSYNC_URL=https://YOUR_POWERSYNC_INSTANCE.powersync.journeyapps.com

# ─── App Variant (used by EAS) ───────────────────────────────
# Values: 'staging' | 'production'
APP_VARIANT=development
